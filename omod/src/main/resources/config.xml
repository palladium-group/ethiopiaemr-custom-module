<?xml version="1.0" encoding="UTF-8"?>

<module configVersion="1.2">
	
	<!-- Base Module Properties -->
	<id>${project.parent.artifactId}</id>
	<name>${project.parent.name}</name>
	<version>${project.parent.version}</version>
	<package>org.openmrs.module.ethiopiaemrcustommodule</package>
	<author>said</author>
	<description>
			${project.parent.description}
	</description>

	<activator>org.openmrs.module.ethiopiaemrcustommodule.EthiopiaEmrCustomModuleActivator</activator>
	<mappingFiles>
		PrescriptionOutbox.hbm.xml
	</mappingFiles>
	
	<!-- <updateURL>https://modules.openmrs.org/modules/download/@MODULE_ID@/update.rdf</updateURL> -->
	<!-- /Base Module Properties -->
	
	<require_version>${openmrsPlatformVersion}</require_version>

	<aware_of_modules>
		<aware_of_module>org.openmrs.module.legacyui</aware_of_module>
	</aware_of_modules>
	<require_modules>
		<require_module version="3.1.0">org.openmrs.module.webservices.rest</require_module>
	</require_modules>

	<!-- Global Properties -->
	<globalProperty>
		<property>ethiopiaemrcustommodule.allowUntrustedSsl</property>
		<defaultValue>false</defaultValue>
		<description>
			Set to true to allow HTTP connections to servers with self-signed or untrusted SSL certificates (equivalent to curl -k).
			Set to false (default) for secure production environments with valid CA certificates.
		</description>
	</globalProperty>

	<!-- Internationalization -->
	<messages>
		<lang>en</lang>
		<file>messages.properties</file>
	</messages>
	<messages>
		<lang>fr</lang>
		<file>messages_fr.properties</file>
	</messages>
	<messages>
		<lang>es</lang>
		<file>messages_es.properties</file>
	</messages>

</module>